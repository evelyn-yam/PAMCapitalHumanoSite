@page "/reset-password/enter-email"

<PageTitle>Restablecer contrasena</PageTitle>

<div class="kt-card auth-sign-in-card">
    <form class="kt-card-content flex flex-col gap-5 p-10" id="reset_password_enter_email_form" @onsubmit="HandleContinue" @onsubmit:preventDefault="true">
        <div class="text-center">
            <h3 class="text-lg font-medium text-mono">Tu correo electronico</h3>
            <span class="text-sm text-secondary-foreground">Ingresa tu correo para restablecer la contrasena</span>
        </div>

        <div class="flex flex-col gap-1">
            <label class="kt-form-label font-normal text-mono" for="reset_password_email">Correo electronico</label>
            <input id="reset_password_email" class="kt-input" placeholder="email@email.com" type="text" @bind="Email" autocomplete="username" />
        </div>

        @if (Submitted)
        {
            <div class="kt-alert kt-alert-light kt-alert-success">
                <div class="kt-alert-title">Correo listo para enviar instrucciones.</div>
            </div>
        }

        <button class="kt-btn kt-btn-primary flex justify-center grow" type="submit">
            Continuar
            <i class="ki-filled ki-black-right"></i>
        </button>
    </form>
</div>

@code {
    private string? Email { get; set; }
    private bool Submitted { get; set; }

    private void HandleContinue()
    {
        Submitted = true;
    }
}
